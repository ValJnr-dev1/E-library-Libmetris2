POSTGRES_USER=elibrary
POSTGRES_PASSWORD=elibrary_secret
POSTGRES_DB=elibrary
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://elibrary:elibrary_secret@db:5432/elibrary

JWT_SECRET=change-me-to-a-long-random-secret-key
JWT_EXPIRY_MINUTES=60

UPLOAD_DIRECTORY=/app/uploads
MAX_UPLOAD_SIZE_MB=25

LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW_SECONDS=60
